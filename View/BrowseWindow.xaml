<Window x:Class="FlashMemo.View.BrowseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Browse"
        Height="700"
        Width="1200"
        MinHeight="450"
        MinWidth="850"
        Background="#FF1E1E1E">

    <Window.Resources>
        <Style x:Key="BrowseCellTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15.4"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FFF0F0F0"/>
        </Style>

        <Style x:Key="BrowseDeletedHiddenTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BrowseCellTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                    <Setter Property="Text" Value=""/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowseDeletedFirstColumnTextStyle" TargetType="TextBlock" BasedOn="{StaticResource BrowseCellTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDeleted}" Value="True">
                    <Setter Property="Text" Value="[CARD DELETED]"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Foreground" Value="#FFFF9C9C"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BrowseHeaderGripThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BrowseHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Background" Value="#FF2A2A2A"/>
            <Setter Property="Foreground" Value="#FF8EC9FF"/>
            <Setter Property="BorderBrush" Value="#FF666666"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,0,8,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid SnapsToDevicePixels="True">
                            <Border
                                x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True"/>
                            </Border>

                            <Border
                                HorizontalAlignment="Right"
                                Width="1"
                                Background="#FF8A8A8A"/>

                            <Thumb
                                x:Name="PART_LeftHeaderGripper"
                                HorizontalAlignment="Left"
                                Width="6"
                                Style="{StaticResource BrowseHeaderGripThumbStyle}"
                                Cursor="SizeWE"/>

                            <Thumb
                                x:Name="PART_RightHeaderGripper"
                                HorizontalAlignment="Right"
                                Width="8"
                                Style="{StaticResource BrowseHeaderGripThumbStyle}"
                                Cursor="SizeWE"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#FF323232"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Border
                HorizontalAlignment="Center"
                Background="#FF2A2A2A"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1"
                CornerRadius="6"
                Padding="8,4"
                Width="420">
                <TextBox
                    Text="{Binding SearchBar, UpdateSourceTrigger=PropertyChanged}"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#FFE6E6E6"
                    CaretBrush="#FFE6E6E6"
                    FontSize="14"
                    VerticalContentAlignment="Center"
                    ToolTip="Search (not wired yet)"/>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="#FF222222"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1"
                CornerRadius="6">
            <DataGrid
                x:Name="CardsGrid"
                AutoGenerateColumns="False"
                ItemsSource="{Binding Cards}"
                IsReadOnly="True"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserResizeColumns="True"
                CanUserReorderColumns="True"
                CanUserSortColumns="True"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                GridLinesVisibility="None"
                HeadersVisibility="Column"
                Background="#FF202020"
                RowBackground="#FF202020"
                AlternatingRowBackground="#FF252525"
                BorderThickness="0"
                Foreground="#FFF0F0F0"
                ColumnHeaderHeight="34"
                ColumnHeaderStyle="{StaticResource BrowseHeaderStyle}">
                <DataGrid.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF2D78D4"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FF2D78D4"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#FFFFFFFF"/>
                </DataGrid.Resources>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#FFF0F0F0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF2D78D4"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#FFF0F0F0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuspended}" Value="True">
                                <Setter Property="Background" Value="#55FFB347"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding IsBuried}" Value="True">
                                <Setter Property="Background" Value="#66D64545"/>
                            </DataTrigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FF2D78D4"/>
                                <Setter Property="Foreground" Value="#FFFFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>
        </Border>
    </Grid>
</Window>
