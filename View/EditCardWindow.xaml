<Window x:Class="FlashMemo.View.EditCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FlashMemo.ViewModel.Windows"
        d:DataContext="{d:DesignInstance Type=vm:CardEditorVM}"
        mc:Ignorable="d"
        Title="Edit Card"
        Width="900"
        Height="650"
        FontSize="24"
        WindowStartupLocation="CenterOwner">
    <Window.Background>
        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
            <GradientStop Color="#FFFF7878"/>
            <GradientStop Color="#FF9B7DF3" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Background="#66000000">

                <TextBlock
                    Text="Move to deck: "
                    Foreground="White"
                    FontSize="18"
                    Margin="10,10,10,10"
                    VerticalAlignment="Center"/>

                <Button
                    Content="{Binding Card.Deck.Name}"
                    Command="{Binding ShowDeckSelectCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    Margin="5,0,0,0"
                    Width="230"
                    Height="34"
                    BorderBrush="#FFDEDEDE"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Margin="0,16,0,8"
                    Padding="12"
                    CornerRadius="12"
                    BorderBrush="{StaticResource NavBorderBrush}"
                    BorderThickness="2">
                <Border.Background>
                    <SolidColorBrush Color="#CC2A2E34"/>
                </Border.Background>

                <Grid>
                    <TextBlock Text="Front:"
                               Foreground="White"
                               FontSize="18"
                               Margin="0,0,0,8"/>

                    <RichTextBox x:Name="FrontBox"
                                 Margin="0,28,0,0"
                                 Background="#22000000"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FontSize}"/>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Margin="0,8,0,16"
                    Padding="12"
                    CornerRadius="12"
                    BorderBrush="{StaticResource NavBorderBrush}"
                    BorderThickness="2"
                    Background="#CC2A2E34">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Back:"
                               Foreground="White"
                               FontSize="18"
                               Margin="0,0,0,8"/>

                    <RichTextBox x:Name="BackBox"
                                 Grid.Row="1"
                                 Margin="0,0,0,10"
                                 Background="#22000000"
                                 Foreground="White"
                                 BorderThickness="0"
                                 FontSize="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FontSize}"/>

                    <Border x:Name="TagInputBorder"
                            Grid.Row="2"
                            Padding="8,5"
                            CornerRadius="8"
                            BorderThickness="1"
                            BorderBrush="#8895A5B8"
                            Background="#22000000">
                        <DockPanel LastChildFill="True">
                            <TextBlock Text="Tags:"
                                       Margin="0,0,8,0"
                                       Foreground="#CCD9E3F0"
                                       VerticalAlignment="Center"
                                       FontSize="17"/>

                            <WrapPanel x:Name="TagChipPanel"
                                       VerticalAlignment="Center">
                                <TextBox x:Name="TagInputBox"
                                         MinWidth="120"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="White"
                                         FontSize="24"
                                         CaretBrush="White"
                                         VerticalContentAlignment="Center"/>
                            </WrapPanel>
                        </DockPanel>
                    </Border>

                    <Popup x:Name="TagSuggestionsPopup"
                           PlacementTarget="{Binding ElementName=TagInputBorder}"
                           Placement="Top"
                           AllowsTransparency="True"
                           StaysOpen="True">
                        <Border Width="{Binding ActualWidth, ElementName=TagInputBorder}"
                                MaxHeight="190"
                                Padding="0"
                                CornerRadius="6"
                                BorderThickness="1"
                                BorderBrush="#AA9BB2CC"
                                Background="#FF31343A">
                            <ListBox x:Name="TagSuggestionsList"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="20"
                                     DisplayMemberPath="Name"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#552F89FF"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#AA2F89FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button
                        Content="Cancel"
                        Command="{Binding CancelChangesCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        Width="90"
                        Height="39"/>

                    <Button
                        Content="Revert"
                        Click="RevertButtonClicked"
                        Style="{StaticResource NavButtonStyle}"
                        Width="90"
                        Height="39"
                        Margin="10,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button
                        Content="Save"
                        Click="SaveButtonClicked"
                        Style="{StaticResource NavButtonStyle}"
                        Width="90"
                        Height="39"/>

                    <Button
                        Name="MoreButton"
                        Content="More"
                        Click="MoreButtonClicked"
                        Style="{StaticResource NavButtonStyle}"
                        Width="90"
                        Height="39"
                        Margin="10,0,0,0">

                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Suspend" Command="{Binding ToggleSuspendedCtxCommand}"/>
                                <MenuItem Header="Forget" Command="{Binding ForgetCardsCtxCommand}"/>
                                <MenuItem Header="Bury" Command="{Binding ToggleBuryCtxCommand}"/>
                                <MenuItem Header="Reschedule" Command="{Binding ShowRescheduleCtxCommand}"/>
                                <MenuItem Header="Delete" Command="{Binding DeleteCardsCtxCommand}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid
            Background="#80000000"
            Visibility="{Binding CurrentPopup,
            Converter={StaticResource NullToVisConverter}}">

            <ContentControl
                Content="{Binding CurrentPopup}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
