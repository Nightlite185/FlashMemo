<UserControl x:Class="FlashMemo.View.RescheduleUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
             PreviewKeyDown="Root_PreviewKeyDown"
             Loaded="Root_Loaded">

    <Border
        Width="420"
        Padding="16"
        Background="#FF1E1E1E"
        CornerRadius="14"
        BorderBrush="{StaticResource NavBorderBrush}"
        BorderThickness="2">

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Text="Reschedule / Postpone"
                FontSize="22"
                FontWeight="SemiBold"
                Foreground="White"
                HorizontalAlignment="Center"
                Margin="0,0,0,16"/>

            <Grid
                Grid.Row="1"
                Margin="0,10,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton
                    Grid.Column="0"
                    GroupName="RescheduleMode"
                    IsChecked="{Binding DatepickerActive, Mode=TwoWay}"
                    Checked="DateOption_Checked"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0">

                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="1.85" ScaleY="1.85" />
                    </RadioButton.LayoutTransform>

                </RadioButton>

                <TextBlock
                    Grid.Column="1"
                    Text="Pick exact date:"
                    Foreground="White"
                    FontSize="15.5"
                    VerticalAlignment="Center"
                    Margin="0,0,10,0"/>

                <DatePicker
                    Grid.Column="2"
                    x:Name="DatePickerControl"
                    IsEnabled="{Binding DatepickerActive}"
                    SelectedDate="{Binding RescheduleToDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    DisplayDateStart="{Binding MinPickableDate, Mode=OneWay}"
                    Height="32"
                    Width="170"
                    HorizontalAlignment="Left"/>
            </Grid>

            <Grid
                Grid.Row="2"
                Margin="0,10,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton
                    Grid.Column="0"
                    GroupName="RescheduleMode"
                    IsChecked="{Binding DatepickerActive, Converter={StaticResource InverseBoolConverter}}"
                    Checked="PostponeOption_Checked"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0">

                    <RadioButton.LayoutTransform>
                        <ScaleTransform ScaleX="1.85" ScaleY="1.85" />
                    </RadioButton.LayoutTransform>

                </RadioButton>

                <TextBlock
                    Grid.Column="1"
                    Text="Postpone by (days):"
                    Foreground="White"
                    Margin="0,0,10,0"
                    FontSize="14.5"
                    VerticalAlignment="Center"/>

                <xceed:UIntegerUpDown
                    Grid.Column="2"
                    x:Name="PostponeByDaysControl"
                    IsEnabled="{Binding DatepickerActive, Converter={StaticResource InverseBoolConverter}}"
                    Style="{StaticResource FlatUIntegerUpDownStyle}"
                    Value="{Binding PostponeByDays, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Minimum="1"
                    Width="110"
                    Margin="0"
                    HorizontalAlignment="Left"/>
            </Grid>

            <CheckBox
                Grid.Row="3"
                Content="Keep interval"
                IsChecked="{Binding KeepInterval, Mode=TwoWay}"
                Foreground="White"
                Margin="0,0,0,16"
                FontSize="8.5"
                VerticalContentAlignment="Center">

                <CheckBox.LayoutTransform>
                    <ScaleTransform ScaleX="1.65" ScaleY="1.65" />
                </CheckBox.LayoutTransform>
            </CheckBox>

            <Grid Grid.Row="4">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Content="Cancel"
                    Command="{Binding CloseCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    Width="90"/>

                <Button
                    Grid.Column="2"
                    Content="Confirm"
                    Command="{Binding ConfirmCommand}"
                    Style="{StaticResource NavButtonStyle}"
                    Width="90"/>
            </Grid>

        </Grid>

    </Border>
</UserControl>
