<Window x:Class="FlashMemo.View.UserOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="User Options"
        Width="800"
        Height="620"
        MinWidth="800"
        MinHeight="520"
        ResizeMode="CanResize"
        Background="#FF1E1E1E"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style x:Key="UserOptHintStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource OptionsLabelStyle}">
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="235"/>
            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            <Setter Property="Margin" Value="0,6,0,6"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP TITLE ================= -->

        <TextBlock Grid.Row="0"
                   Text="User Options"
                   HorizontalAlignment="Center"
                   Foreground="White"
                   FontSize="32"
                   FontWeight="SemiBold"
                   Margin="0,0,0,18"/>

        <!-- ================= CONTENT ================= -->

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <Border Style="{StaticResource OptionsCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="310"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Text="Day starts at (hour)"
                        Style="{StaticResource UserOptHintStyle}"
                        ToolTip="How many hours past midnight need to pass, for scheduler to consider it as the next day."/>

                    <xceed:UIntegerUpDown
                        Grid.Column="1"
                        Margin="0,6,0,6"
                        Style="{StaticResource FlatUIntegerUpDownStyle}"
                        Value="{Binding Options.DayStartOffset}"
                        Minimum="0"
                        Maximum="12"
                        MaxLength="2"/>

                    <TextBlock
                        Grid.Row="1"
                        Text="Show review timer"
                        Style="{StaticResource UserOptHintStyle}"/>

                    <CheckBox
                        Grid.Row="1"
                        Grid.Column="1"
                        IsChecked="{Binding Options.ShowReviewTimer}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,6">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.65" ScaleY="1.65"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                    <TextBlock
                        Grid.Row="2"
                        Text="Timer stops on reveal"
                        Style="{StaticResource UserOptHintStyle}"
                        ToolTip="When enabled, timer stops as soon as the answer is shown."/>

                    <CheckBox
                        Grid.Row="2"
                        Grid.Column="1"
                        IsChecked="{Binding Options.TimerStopsOnReveal}"
                        IsEnabled="{Binding Options.ShowReviewTimer}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,6">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.65" ScaleY="1.65"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                    <TextBlock
                        Grid.Row="3"
                        Style="{StaticResource UserOptHintStyle}"
                        ToolTip="When enabled, daily lesson cards count toward daily review limit." 
                        Text="Include lessons in reviews limit"/>

                    <CheckBox
                        Grid.Row="3"
                        Grid.Column="1"
                        IsChecked="{Binding Options.IncludeLessonsInReviewLimit}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,6">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.65" ScaleY="1.65"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                    <TextBlock
                        Grid.Row="4"
                        Style="{StaticResource UserOptHintStyle}"
                        ToolTip="whether card's interval will increase scaling off its current overdueness"
                        Text="Interval scaling on overdueness"/>

                    <CheckBox
                        Grid.Row="4"
                        Grid.Column="1"
                        IsChecked="{Binding Options.IntervalScalingOnOverdueness}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,6">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.65" ScaleY="1.65"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                    <TextBlock
                        Grid.Row="5"
                        Style="{StaticResource UserOptHintStyle}"
                        ToolTip="When enabled, review heatmap is visible on the decks screen."
                        Text="Show review heatmap"/>

                    <CheckBox
                        Grid.Row="5"
                        Grid.Column="1"
                        IsChecked="{Binding Options.ShowHeatmap}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,6,0,6">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.65" ScaleY="1.65"/>
                        </CheckBox.LayoutTransform>
                    </CheckBox>

                </Grid>
            </Border>

        </ScrollViewer>

        <!-- ================= BOTTOM ACTIONS ================= -->

        <Grid Grid.Row="2"
              Margin="0,12,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal">
                <Button
                    Content="Cancel"
                    Width="100"
                    IsCancel="True"
                    Style="{StaticResource NavButtonStyle}"/>

                <Button
                    Content="Revert"
                    Width="100"
                    Margin="8,0,0,0"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding RevertChangesCommand}"/>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal">
                <Button
                    Content="To Default"
                    Width="120"
                    Margin="0,0,8,0"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding ToDefaultCommand}"/>

                <Button
                    Content="Save"
                    Width="100"
                    Style="{StaticResource NavButtonStyle}"
                    Command="{Binding SaveChangesCommand}"/>
            </StackPanel>

        </Grid>

    </Grid>
</Window>
